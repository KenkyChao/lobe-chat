# This file is only an example for the observability compose template.
# The recommended source of truth is the repository root .env.prod file.

# ===========================
# ===== NaiYunHub image =====
# ===========================
NAIYUNCHAT_DB_VERSION=2.2.4

# ===========================
# ===== Service ports =======
# ===========================
LOBE_PORT=3010
GRAFANA_PORT=3000
OTEL_HTTP_PORT=4318
OTEL_GRPC_PORT=4317

# ===========================
# ===== Application URL =====
# ===========================
APP_URL=https://chat.naiyun.com

# ===========================
# ===== Secret config =======
# ===========================
AUTH_SECRET=CHANGE_ME
KEY_VAULTS_SECRET=CHANGE_ME

# ===========================
# ===== Local containers ====
# ===========================
LOBE_DB_NAME=postgres
POSTGRES_PASSWORD=postgres
REDIS_PREFIX=lobechat

# ===========================
# ===== External Casdoor ====
# ===========================
AUTH_SSO_PROVIDERS=casdoor
AUTH_CASDOOR_ISSUER=https://your-casdoor.example.com
AUTH_CASDOOR_ID=CHANGE_ME
AUTH_CASDOOR_SECRET=CHANGE_ME
CASDOOR_WEBHOOK_SECRET=CHANGE_ME

# ===========================
# ===== External S3/MinIO ===
# ===========================
S3_ENDPOINT=https://your-minio.example.com
S3_PUBLIC_DOMAIN=https://your-minio.example.com
S3_BUCKET=lobe
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME
S3_ENABLE_PATH_STYLE=1
S3_SET_ACL=0
LLM_VISION_IMAGE_USE_BASE64=1

# ===========================
# ===== Search providers ====
# ===========================
SEARCH_PROVIDERS=searxng,anspire

# ===========================
# ===== Observability =======
# ===========================
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME
